---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title?: string;
}
const { title = 'rjrivera — portfolio' } = Astro.props;
---

<BaseLayout title={title}>
  <Sidebar />
  <main class="project-main">
    <slot />
  </main>
</BaseLayout>

<style>
  .project-main {
    margin-left: 320px;
    min-height: 100vh;
    padding: 2.5rem 3rem;
  }

  @media (max-width: 768px) {
    .project-main {
      margin-left: 0;
      padding: 5rem 1.5rem 2rem;
    }
  }
</style>
