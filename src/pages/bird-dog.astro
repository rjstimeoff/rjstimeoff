---
import ProjectLayout from '../layouts/ProjectLayout.astro';
---

<ProjectLayout title="Bird Dog — rjrivera">
  <div class="project-header">
    <h1 class="project-title">Bird Dog</h1>
    <div class="project-tags">
      <span>Tool Design</span>
      <span>Product Strategy</span>
      <span>Front End</span>
    </div>
  </div>

  <div class="project-hero">
    <img src="/bird_dog_collage.png" alt="Bird Dog" />
  </div>

  <p class="project-intro">Bird dog is a reimaginated version of LinkedIn that focuses on a better user experience, and incorporates useful AI native tools that users like me actually want.</p>

  <p class="project-body">I wanted to see if I could take the AI tools I built to help me job hunt, and weave them into a better version of LinkedIn. I started out with a basic web app I built for personal use, and then built a whole ecosystem around them. It was a cool opportunity to work on building out a full ecosystem and figure out how to make every little part not only work together, but feel great.</p>

  <p class="project-body">There are some really awesome additions like the referral system, the integrated role fit analysis on the jobs page, an overhauled profile page, a thoughtful application tracker, and of course... the resume workshop (which was the hardest thing to build).</p>

  <img class="handwritten-note" src="/click_through_tabs.png" alt="click through the tabs" />

  <div class="browser-frame">

    <!-- Tab strip -->
    <div class="browser-tab-strip">
      <div class="traffic-lights">
        <span class="tl tl-red"></span>
        <span class="tl tl-yellow"></span>
        <span class="tl tl-green"></span>
      </div>
      <div class="tab-strip-tabs">
        <button class="tab-btn active" data-tab="0" data-url="bird-dog.app/home">Home</button>
        <button class="tab-btn" data-tab="1" data-url="bird-dog.app/profile">Profile</button>
        <button class="tab-btn" data-tab="2" data-url="bird-dog.app/jobs">Jobs</button>
        <button class="tab-btn" data-tab="3" data-url="bird-dog.app/resume-workshop">Resume Workshop</button>
        <button class="tab-btn" data-tab="4" data-url="bird-dog.app/tracker">Tracker</button>
      </div>
    </div>

    <!-- Toolbar -->
    <div class="browser-toolbar">
      <div class="nav-btns">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 12L6 8l4-4"/></svg>
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 12l4-4-4-4"/></svg>
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 8A5 5 0 1 1 8 3a5 5 0 0 1 3.54 1.46M13 3v3h-3"/></svg>
      </div>
      <div class="url-bar">
        <svg class="lock-icon" viewBox="0 0 16 16" fill="currentColor"><path d="M11 7V5a3 3 0 0 0-6 0v2H4v7h8V7h-1zm-4-2a1 1 0 0 1 2 0v2H7V5z"/></svg>
        <span class="url-text" id="url-display">bird-dog.app/home</span>
      </div>
    </div>

    <!-- Video panels -->
    <div class="tab-panels">
      <div class="tab-panel active" data-panel="0">
        <div class="vimeo-wrapper">
          <iframe src="https://player.vimeo.com/video/1183089656?autopause=0&muted=1&controls=0&loop=1&title=0&byline=0&portrait=0" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
        </div>
      </div>
      <div class="tab-panel" data-panel="1">
        <div class="vimeo-wrapper">
          <iframe src="https://player.vimeo.com/video/1183089722?autopause=0&muted=1&controls=0&loop=1&title=0&byline=0&portrait=0" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
        </div>
      </div>
      <div class="tab-panel" data-panel="2">
        <div class="vimeo-wrapper">
          <iframe src="https://player.vimeo.com/video/1183089680?autopause=0&muted=1&controls=0&loop=1&title=0&byline=0&portrait=0" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
        </div>
      </div>
      <div class="tab-panel" data-panel="3">
        <div class="vimeo-wrapper">
          <iframe src="https://player.vimeo.com/video/1183089760?autopause=0&muted=1&controls=0&loop=1&title=0&byline=0&portrait=0" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
        </div>
      </div>
      <div class="tab-panel" data-panel="4">
        <div class="vimeo-wrapper">
          <iframe src="https://player.vimeo.com/video/1183089781?autopause=0&muted=1&controls=0&loop=1&title=0&byline=0&portrait=0" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
        </div>
      </div>
    </div>

  </div>

  <p class="gallery-caption">Some marketing/promotional content I made when building the first version(s) of Bird Dog.</p>

  <div class="media-gallery">
    <div class="media-item span-2">
      <img src="/bird_dog_man_and_dog.png" alt="Man and dog poster" />
    </div>
    <div class="media-item">
      <img src="/bird_dog_with_bird.png" alt="Dog with bird poster" />
    </div>
    <div class="media-item">
      <img src="/bird_dog_logo.png" alt="Bird Dog logo" />
    </div>
    <div class="media-item span-2">
      <video src="/bird_dog_generated_clip.mp4" muted loop playsinline autoplay></video>
    </div>
  </div>

</ProjectLayout>

<script>
  const vimeoScript = document.createElement('script');
  vimeoScript.src = 'https://player.vimeo.com/api/player.js';
  vimeoScript.onload = () => {
    const buttons = document.querySelectorAll('.tab-btn');
    const panels = document.querySelectorAll('.tab-panel');
    const urlDisplay = document.getElementById('url-display');
    const players = [];

    panels.forEach((panel, i) => {
      const iframe = panel.querySelector('iframe');
      if (iframe) players[i] = new Vimeo.Player(iframe);
    });

    if (players[0]) players[0].play();

    buttons.forEach((btn, i) => {
      btn.addEventListener('click', () => {
        const activeIndex = [...panels].findIndex(p => p.classList.contains('active'));
        if (players[activeIndex]) players[activeIndex].pause();

        buttons.forEach(b => b.classList.remove('active'));
        panels.forEach(p => p.classList.remove('active'));

        btn.classList.add('active');
        panels[i].classList.add('active');

        if (urlDisplay) urlDisplay.textContent = btn.dataset.url;
        if (players[i]) players[i].play();
      });
    });
  };
  document.head.appendChild(vimeoScript);
</script>

<style>
  .project-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .project-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .project-tags span {
    font-family: Garamond, 'EB Garamond', Georgia, serif;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: #999;
    font-style: italic;
  }

  .project-title {
    font-family: Garamond, 'EB Garamond', Georgia, serif;
    font-size: 0.9rem;
    font-weight: normal;
    letter-spacing: 0.08em;
    color: #1c1f23;
  }

  .project-hero {
    width: 100%;
    overflow: hidden;
  }

  .project-hero img {
    width: calc(100% + 20px);
    height: auto;
    display: block;
    margin-top: -3px;
    margin-bottom: -3px;
    margin-left: -10px;
  }

  .project-intro {
    font-family: Garamond, 'EB Garamond', Georgia, serif;
    font-size: 0.9rem;
    color: #1c1f23;
    letter-spacing: 0.02em;
    line-height: 1.7;
    max-width: none;
    white-space: nowrap;
    margin-top: 0.75rem;
  }

  .project-body {
    font-family: Garamond, 'EB Garamond', Georgia, serif;
    font-size: 0.9rem;
    color: #1c1f23;
    letter-spacing: 0.02em;
    line-height: 1.7;
    max-width: 680px;
    margin-top: 1.75rem;
  }

  .handwritten-note {
    display: block;
    width: 280px;
    margin-top: -7rem;
    margin-bottom: -13rem;
    margin-left: -1rem;
    opacity: 0.75;
  }

  /* ── Browser frame ── */
  .browser-frame {
    margin-top: 4rem;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0,0,0,0.18);
  }

  /* Tab strip */
  .browser-tab-strip {
    display: flex;
    align-items: flex-end;
    background: #35363a;
    padding: 8px 12px 0 12px;
    gap: 0;
  }

  .traffic-lights {
    display: flex;
    align-items: center;
    gap: 6px;
    padding-bottom: 8px;
    margin-right: 12px;
    flex-shrink: 0;
  }

  .tl {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .tl-red    { background: #ff5f57; }
  .tl-yellow { background: #febc2e; }
  .tl-green  { background: #28c840; }

  .tab-strip-tabs {
    display: flex;
    align-items: flex-end;
    gap: 0;
  }

  .tab-btn {
    position: relative;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.72rem;
    font-weight: 400;
    color: #9aa0a6;
    background: #2d2e32;
    border: none;
    border-radius: 8px 8px 0 0;
    padding: 6px 16px 7px 16px;
    margin-right: 2px;
    cursor: pointer;
    white-space: nowrap;
    z-index: 1;
  }

  /* Inward curved corners — Chrome tab shape */
  .tab-btn::before,
  .tab-btn::after {
    content: '';
    position: absolute;
    bottom: 0;
    width: 5px;
    height: 5px;
    background: transparent;
  }
  .tab-btn::before {
    left: -5px;
    border-bottom-right-radius: 5px;
    box-shadow: 3px 0 0 0 #2d2e32;
  }
  .tab-btn::after {
    right: -5px;
    border-bottom-left-radius: 5px;
    box-shadow: -3px 0 0 0 #2d2e32;
  }

  .tab-btn:hover {
    color: #e8eaed;
    background: #3c3d41;
  }
  .tab-btn:hover::before { box-shadow: 3px 0 0 0 #3c3d41; }
  .tab-btn:hover::after  { box-shadow: -3px 0 0 0 #3c3d41; }

  .tab-btn.active {
    color: #202124;
    background: #ffffff;
    z-index: 2;
  }
  .tab-btn.active::before { box-shadow: 3px 0 0 0 #ffffff; }
  .tab-btn.active::after  { box-shadow: -3px 0 0 0 #ffffff; }

  /* Toolbar */
  .browser-toolbar {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #ffffff;
    padding: 6px 12px;
    border-bottom: 1px solid #e0e0e0;
  }

  .nav-btns {
    display: flex;
    align-items: center;
    gap: 2px;
    flex-shrink: 0;
  }

  .nav-btns svg {
    width: 18px;
    height: 18px;
    color: #9aa0a6;
  }

  .url-bar {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 6px;
    background: #f1f3f4;
    border-radius: 20px;
    padding: 4px 12px;
  }

  .lock-icon {
    width: 12px;
    height: 12px;
    color: #5f6368;
    flex-shrink: 0;
  }

  .url-text {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.75rem;
    color: #202124;
    letter-spacing: 0;
  }

  /* Panels */
  .tab-panel {
    display: none;
  }

  .tab-panel.active {
    display: block;
  }

  .vimeo-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 3404 / 1836;
    overflow: hidden;
  }

  .vimeo-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .gallery-caption {
    font-family: Garamond, 'EB Garamond', Georgia, serif;
    font-size: 0.9rem;
    color: #999;
    font-style: italic;
    letter-spacing: 0.02em;
    margin-top: 8rem;
  }

  /* ── Media gallery ── */
  .media-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1rem;
  }

  .media-item {
    overflow: hidden;
    border-radius: 6px;
  }

  .media-item.span-2 { grid-column: span 2; }
  .media-item.span-3 { grid-column: span 3; }

  .media-item img,
  .media-item video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
